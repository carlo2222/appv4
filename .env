# File .env reale, letto dall'app. Non condividerlo né metterlo su GitHub
# (è già escluso in .gitignore).

# ============================================================
# DA MODIFICARE TU: un solo campo, preso da Neon (neon.tech)
# ============================================================
# 1. Vai su neon.tech, crea un account gratuito (nessuna carta richiesta),
#    crea un progetto.
# 2. Nella dashboard del progetto, clicca il pulsante "Connect".
# 3. Ti mostra UNA stringa già pronta, tipo:
#    postgresql://alex:AbC123dEf@ep-cool-darkness-a1b2c3d4-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
# 4. Copiala e incollala qui sotto, al posto dell'esempio.
DATABASE_URL=postgresql://utente:password@ep-esempio-pooler.regione.aws.neon.tech/neondb?sslmode=require

# ============================================================
# Il resto è già pronto — modificalo solo se vuoi personalizzare
# ============================================================

PORT=4000

# Già generato in modo casuale e sicuro (non serve toccarlo).
JWT_SECRET=b5a2c829c9e0fab2df3465edb05e6d7da6bbb10385a2af21bfa83f6c22bdcc7f
JWT_EXPIRES_IN=7d

# Credenziali del primo amministratore. Vengono usate SOLO al primissimo
# avvio (se non esiste ancora nessun admin nel database) per crearne uno
# automaticamente. Cambiale pure prima del primo avvio, se vuoi.
BOOTSTRAP_ADMIN_EMAIL=admin@pecs1695.it
BOOTSTRAP_ADMIN_PASSWORD=CambiaQuestaPassword123

# Email transazionali (facoltativo: se lasci RESEND_API_KEY vuota, l'app
# funziona comunque, semplicemente non manda le email — vedi README).
RESEND_API_KEY=
EMAIL_FROM=PECS 1695 2026 <onboarding@resend.dev>
